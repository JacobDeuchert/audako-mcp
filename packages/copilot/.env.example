# Copilot Server Configuration
PORT=3001
HOST=0.0.0.0

# CORS Configuration
# Comma-separated list of allowed origins. Use '*' to allow all origins.
CORS_ORIGINS=*

# Session Configuration
# Idle session timeout in milliseconds (default: 1800000 = 30 minutes)
SESSION_IDLE_TIMEOUT=1800000

# LLM Configuration
LLM_PROVIDER=anthropic
LLM_MODEL_NAME=anthropic/claude-sonnet-4-20250514

# Mutation Throttle (milliseconds between create/update requests)
MUTATION_DELAY_MS=150

# Request Timeout (milliseconds for question/prompt requests, default: 120000 = 2 minutes)
QUESTION_TIMEOUT_MS=120000

# Logging
LOG_LEVEL=info
