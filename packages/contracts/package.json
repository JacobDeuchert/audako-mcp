{
  "name": "@audako/contracts",
  "version": "0.1.0",
  "private": false,
  "description": "Shared TypeScript contracts for Audako services and clients",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./copilot": {
      "types": "./src/copilot.ts",
      "import": "./dist/copilot.js",
      "default": "./dist/copilot.js"
    },
    "./copilot/ws-events": {
      "types": "./src/copilot-ws-events.ts",
      "import": "./dist/copilot-ws-events.js",
      "default": "./dist/copilot-ws-events.js"
    },
    "./question": {
      "types": "./src/question.ts",
      "import": "./dist/question.js",
      "default": "./dist/question.js"
    },
    "./common": {
      "types": "./src/common.ts",
      "import": "./dist/common.js",
      "default": "./dist/common.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
